    padding: 0.65rem 0.5rem;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    background: white;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    font-weight: 400;
