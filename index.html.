<canvas id="canvas" width="174" height="62"></canvas>

<script>
  const COLOURS = [
    { name: 'Fiery Red',        hex: '#b73230' },
    { name: 'Cool Blue',        hex: '#0071bb' },
    { name: 'Sunshine Yellow',  hex: '#fdc94f' },
    { name: 'Earth Green',      hex: '#8aa60f' },
  ];

  const selects = ['pos1','pos2','pos3','pos4'];
  let selectedType = 'Classic';

  // Style the selects with colour borders on load
  selects.forEach(id => styleSelect(document.getElementById(id)));

  function styleSelect(sel) {
    const colour = COLOURS.find(c => c.name === sel.value);
    if (colour) {
      sel.style.borderLeftColor = colour.hex;
      sel.style.borderLeftWidth = '4px';
    }
  }

  function selectType(btn) {
    document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    selectedType = btn.dataset.type;
    updatePreview();
  }

  function getSelections() {
    return selects.map(id => document.getElementById(id).value);
  }

  function validate() {
    const vals = getSelections();
    const unique = new Set(vals);
    if (unique.size < 4) return 'Please make sure each position has a different colour.';
    return null;
  }

  function getSlashAfter() {
    return selectedType === 'Focused' ? 1 : selectedType === 'Classic' ? 2 : 3;
  }

  function updatePreview() {
    selects.forEach(id => styleSelect(document.getElementById(id)));
    const vals = getSelections();
    const slashAfter = getSlashAfter();
    const container = document.getElementById('previewBlocks');
    container.innerHTML = '';

    vals.forEach((name, i) => {
      const colour = COLOURS.find(c => c.name === name);
      const block = document.createElement('div');
      block.className = 'preview-block';
      block.style.background = colour ? colour.hex : '#ccc';
      container.appendChild(block);

      if (i + 1 === slashAfter) {
        const slashWrap = document.createElement('div');
        slashWrap.className = 'preview-slash-wrap';
        slashWrap.innerHTML = `<svg width="10" height="40" viewBox="0 0 10 40"><line x1="8" y1="0" x2="2" y2="40" stroke="#505050" stroke-width="2" stroke-linecap="round"/></svg>`;
        container.appendChild(slashWrap);
      }
    });
  }

  function downloadPNG() {
    const err = validate();
    const errEl = document.getElementById('errorMsg');
    if (err) {
      errEl.textContent = err;
      errEl.style.display = 'block';
      return;
    }
    errEl.style.display = 'none';

    const vals = getSelections();
    const slashAfter = getSlashAfter();

    // Canvas dimensions - email signature sized, square blocks
    const blockW = 40;
    const blockH = 40;
    const slashW = 14;
    const textH  = 22;
    const totalW = (4 * blockW) + slashW;
    const totalH = textH + blockH;

    const canvas = document.getElementById('canvas');
    canvas.width  = totalW;
    canvas.height = totalH;
    const ctx = canvas.getContext('2d');

    // White background
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, totalW, totalH);

    // Text
    ctx.fillStyle = '#505050';
    ctx.font = 'bold 17px Calibri, Arial, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('My Insights colours are:', totalW / 2, textH / 2);

    // Colour blocks
    let x = 0;
    vals.forEach((name, i) => {
      const colour = COLOURS.find(c => c.name === name);
      ctx.fillStyle = colour ? colour.hex : '#cccccc';
      ctx.fillRect(x, textH, blockW, blockH);
      x += blockW;

      if (i + 1 === slashAfter) {
        // White strip
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(x, textH, slashW, blockH);
        // Slash line
        ctx.beginPath();
        ctx.moveTo(x + slashW * 0.75, textH);
        ctx.lineTo(x + slashW * 0.25, textH + blockH);
        ctx.strokeStyle = '#505050';
        ctx.lineWidth = 3;
        ctx.lineCap = 'round';
        ctx.stroke();
        x += slashW;
      }
    });

    // Download
    const link = document.createElement('a');
    link.download = 'InsightsSignature.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  }

  // Initial render
  updatePreview();
</script>



